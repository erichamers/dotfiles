# window specific configs
for_window [class="qutebrowser"] fullscreen enable
for_window [class="VirtualBox Machine"] floating enable

# change container layout (tabbed, toggle split)
# bindsym $mod+s layout stacking
bindsym $mod+t layout tabbed
bindsym $mod+p layout toggle split

# open apps
bindsym $mod+m exec pcmanfm

# move focused container to workspace
bindsym $mod+Shift+a move container to workspace number 1
bindsym $mod+Shift+s move container to workspace number 2
bindsym $mod+Shift+d move container to workspace number 3

# switch to workspace
bindsym $mod+a workspace number 1
bindsym $mod+s workspace number 2
bindsym $mod+d workspace number 3

# workspaces
set $ws1 1
set $ws2 2
set $ws3 3

# keybinds 
bindsym $mod+Return exec alacritty 
bindsym $mod+Tab workspace next
bindsym $mod+f fullscreen 
bindsym $mod+Ctrl+Right resize shrink width 1 px or 1 ppt
bindsym $mod+Ctrl+Up resize grow height 1 px or 1 ppt
bindsym $mod+Ctrl+Down resize shrink height 1 px or 1 ppt
bindsym $mod+Ctrl+Left resize grow width 1 px or 1 ppt
bindsym $mod+i move left
bindsym $mod+o move right

# remove border
for_window [class=".*"] border pixel 1

# qutebrowser
bindsym $mod+b exec qutebrowser

# autoset wallpaper at startup
exec nitrogen --restore & 
exec unclutter --timeout 1
exec_always /bin/bash /home/eric/.config/i3/launch_top.sh &
exec_always picom &

# i3-gaps
gaps outer 75
gaps inner 15
smart_borders on

# colors
client.focused #f8f8f2 #f8f8f2 #f8f8f2 #f8f8f2 #f8f8f2
client.unfocused #6272a4 #6272a4 #6272a4 #6272a4 #6272a4 

# misc
mouse_warping none
focus_follows_mouse no
focus_wrapping no

